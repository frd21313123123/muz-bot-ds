# Токен бота — https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Client ID (Application ID) — https://discord.com/developers/applications → General Information
CLIENT_ID=your_client_id_here

# (Опционально) ID сервера для мгновенной регистрации команд на 1 сервере
# GUILD_ID=your_guild_id_here
